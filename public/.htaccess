RewriteEngine On

# =====================================================
# HTTPS Enforcement
# =====================================================
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# =====================================================
# Trailing Slash Enforcement (matches Astro trailingSlash: 'always')
# Skip files with extensions (assets, images, etc.)
# =====================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteRule ^(.*)$ /$1/ [L,R=301]

# =====================================================
# TinaCMS Admin
# =====================================================
RewriteRule ^admin$ /admin/index.html [L]

# =====================================================
# 301 Redirects — Fix Known URLs
# =====================================================

# /cv → /about/
RewriteRule ^cv/?$ /about/ [L,R=301]

# =====================================================
# Old slug → new slug redirects (accent normalization)
# =====================================================
RewriteRule ^blog/audit-seo-technique--les-10-erreurs-fatales-qui-ruinent-votre-visibilit-en-2026/$ /blog/audit-seo-technique--les-10-erreurs-fatales-qui-ruinent-votre-visibilite-en-2026/ [L,R=301]

RewriteRule ^blog/combien-cote-un-audit-seo-en-2026--le-vrai-prix-de-la-performance/$ /blog/combien-coute-un-audit-seo-en-2026--le-vrai-prix-de-la-performance/ [L,R=301]

RewriteRule ^blog/comment-russir-un-test-ab-e-commerce--guide-complet/$ /blog/comment-reussir-un-test-ab-e-commerce--guide-complet/ [L,R=301]

RewriteRule ^blog/la-rcession-silencieuse--5-dettes-techniques-qui-tuent-votre-rentabilit-shopify-en-2026/$ /blog/la-recession-silencieuse--5-dettes-techniques-qui-tuent-votre-rentabilite-shopify-en-2026/ [L,R=301]

RewriteRule ^blog/le-roi-du-seo--combien-rapporte-vraiment-la-1re-place--analyse-2026/$ /blog/le-roi-du-seo--combien-rapporte-vraiment-la-1ere-place--analyse-2026/ [L,R=301]

RewriteRule ^blog/pourquoi-un-consultant-seo-pas-cher-va-vous-coter-cher-analyse-2026/$ /blog/pourquoi-un-consultant-seo-pas-cher-va-vous-couter-cher-analyse-2026/ [L,R=301]

# Even older slug version (no --analyse-2026 suffix)
RewriteRule ^blog/le-roi-du-seo--combien-rapporte-vraiment-la-1re-place/$ /blog/le-roi-du-seo--combien-rapporte-vraiment-la-1ere-place--analyse-2026/ [L,R=301]

# =====================================================
# Custom 404 page
# =====================================================
ErrorDocument 404 /404/index.html

# =====================================================
# Security Headers
# =====================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# =====================================================
# Cache Control — Static Assets (1 year)
# =====================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Hashed assets (immutable)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|avif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Fonts
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Sitemap and RSS — short cache for fresh content
    <FilesMatch "(sitemap.*\.xml|rss\.xml)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # HTML pages — no long cache
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
</IfModule>

# =====================================================
# GZIP Compression
# =====================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE text/xml application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
